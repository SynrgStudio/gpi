{
  "name": "gpi",
  "version": "0.0.8",
  "description": "GPi: a glass cockpit GUI for Pi with first-class multi-project and multi-session workflows.",
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "check": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "dev": "vite --host 127.0.0.1",
    "dev:electron": "node scripts/dev-electron.mjs",
    "compile:electron": "tsc -p tsconfig.electron.json",
    "test:unit": "node -e \"fs.rmSync('dist-test',{recursive:true,force:true})\" && tsc -p tsconfig.test.json && node --test \"dist-test/test/**/*.test.js\"",
    "build": "tsc --noEmit && tsc -p tsconfig.electron.json && vite build",
    "package:win": "npm run build && node scripts/package-win.mjs",
    "installer:win": "npm run package:win && node scripts/build-installer-win.mjs",
    "release:notes": "node scripts/validate-release-notes.mjs",
    "release:prepare": "node scripts/prepare-release.mjs"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "latest",
    "@vitejs/plugin-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@types/node": "latest",
    "electron": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest"
  },
  "engines": {
    "node": ">=22"
  }
}
